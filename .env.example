# SupplierPass database mode
# Use sqlite for local demo/testing, sqlserver for production-style deployments.
SUPPLIERPASS_DB_MODE=sqlite
SUPPLIERPASS_SQLITE_PATH=data/supplierpass.db

# SQL Server settings. Used only when SUPPLIERPASS_DB_MODE=sqlserver.
SUPPLIERPASS_SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
SUPPLIERPASS_SQLSERVER_HOST=localhost
SUPPLIERPASS_SQLSERVER_DATABASE=SupplierPass
SUPPLIERPASS_SQLSERVER_TRUSTED_CONNECTION=yes
SUPPLIERPASS_SQLSERVER_TRUST_CERT=yes

# If using SQL login instead of Windows trusted connection:
# SUPPLIERPASS_SQLSERVER_TRUSTED_CONNECTION=no
# SUPPLIERPASS_SQLSERVER_USER=your_user
# SUPPLIERPASS_SQLSERVER_PASSWORD=your_password

# Optional: provide a full ODBC connection string instead of the separate settings above.
# SUPPLIERPASS_SQLSERVER_ODBC_CONNECTION=DRIVER={ODBC Driver 18 for SQL Server};SERVER=localhost;DATABASE=SupplierPass;Trusted_Connection=yes;TrustServerCertificate=yes

# Future ERP source settings. Start with read-only SQL views/staging, not direct ERP writes.
SUPPLIERPASS_ERP_SOURCE_NAME=Sage200
SUPPLIERPASS_ERP_SQLSERVER_HOST=YOUR_ERP_SQL_SERVER
SUPPLIERPASS_ERP_SQLSERVER_DATABASE=YOUR_ERP_DATABASE
